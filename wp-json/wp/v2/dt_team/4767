{"id":4767,"date":"2021-05-14T13:49:07","date_gmt":"2021-05-14T11:49:07","guid":{"rendered":"http:\/\/154.0.202.153\/?post_type=dt_team&#038;p=4767"},"modified":"2021-08-17T09:51:26","modified_gmt":"2021-08-17T07:51:26","slug":"geingob-hage","status":"publish","type":"dt_team","link":"https:\/\/www.parliament.na\/dt_team\/geingob-hage\/","title":{"rendered":"Geingob Hage"},"content":{"rendered":"<table width=\"100%\" align=\"left\">\n<tbody>\n<tr>\n<td><img decoding=\"async\" class=\"alignnone size-full wp-image-4768\" src=\"https:\/\/www.parliament.na\/wp-content\/uploads\/2021\/05\/51_hon__hage_geingob.jpg\" alt=\"\" width=\"137\" height=\"197\" \/><\/td>\n<td valign=\"top\">\n<p class=\"contact-position\"><strong>Prime Minister<\/strong><\/p>\n<p class=\"contact-country\">SWAPO Party<\/p>\n<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\" width=\"25%\"><strong>Legislative Profile<\/strong><\/td>\n<td>Chairman of the Constituent Assembly of the Republic of Namibia 1990; First Prime Minister of the Republic of Namibia 1990 \u2013 2002; Chief Whip of SWAPO Party (National Assembly) 2007 \u2013 2008; Vice President of South West Africa People\u2019s Organization (SWAPO) since 2005; Minister of Trade and Industry 2008 \u2013 2012; Prime Minister since 2012<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Personal<\/strong><\/td>\n<td>Born on 3 August 1941 at Otjiwarongo, Otjozondjupa Region<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Education<\/strong><\/td>\n<td>Augustineum Training College 1958 &#8211; 1961; Fordham University (New York) 1964 &#8211; 1970; Graduate Faculty of the New School , New York (MA in International Relations) 1971 &#8211; 1974; Awarded the Palmes Academiques (Officer Class) by the French Government in Recognition of Valuable Service in Education 1980; Awarded Ongulumbashe Medal (SWAPO) for Bravery and Long Service 1987; Awarded LL.D Honoris Causa by Colombia College Illinois, Awarded the Second Highest Order on Cuba \u2013 Carlos Manuel de Cespedes, Awarded the Order of the Sun 1st Class for Outstanding Political Leadership by the Namibian Government 1994; Awarded LL.D (Doctorate of Laws) Honoris Causa by the University of Namibia 1997; Awarded LL.D (Doctorate of Laws) Honoris Causa by the University of Delhi, India 1995; Awarded Doctorate of Humane Letters (Honoris Causa) by the American University of Rome 1998; Ph.D. from University of Leeds 2004 University of Leeds; Awarded the Crans Montana Forum\u2019s Prix de la Foundation for Exceptional Leadership 2012;<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Career<\/strong><\/td>\n<td>Assistant SWAPO Representative in Botswana 1963 \u2013 1964; SWAPO Representative at the United Nations &amp; the Americas 1964 \u2013 1971; Political Affairs Officer, UN Secretariat 1971 \u2013 1975; SWAPO Party\u2019s Director of Elections 1989; Chairman of the 14th Meeting of Experts on the United Nations Programme in Public Administration and Finance 1998; Member of the International Board of Governors of the Centre for International Governance Innovation (CIGI) of Canada 2004; Executive Secretary of the Global Coalition in Washington, DC 2003 \u2013 2004;<\/td>\n<\/tr>\n<tr>\n<td><strong>Interests<\/strong><\/td>\n<td>None<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n","protected":false},"excerpt":{"rendered":"<p>Prime Minister SWAPO Party Legislative Profile Chairman of the Constituent Assembly of the Republic of Namibia 1990; First Prime Minister of the Republic of Namibia 1990 \u2013 2002; Chief Whip of SWAPO Party (National Assembly) 2007 \u2013 2008; Vice President of South West Africa People\u2019s Organization (SWAPO) since 2005; Minister of Trade and Industry 2008&hellip;<\/p>\n","protected":false},"featured_media":4768,"comment_status":"closed","ping_status":"closed","template":"","dt_team_category":[113,110,108,106,105],"class_list":["post-4767","dt_team","type-dt_team","status-publish","has-post-thumbnail","hentry","dt_team_category-1st-national-assembly-1990-1995","dt