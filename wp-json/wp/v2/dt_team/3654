{"id":3654,"date":"2021-04-09T13:56:42","date_gmt":"2021-04-09T11:56:42","guid":{"rendered":"http:\/\/154.0.202.153\/?post_type=dt_team&#038;p=3654"},"modified":"2025-03-31T17:49:27","modified_gmt":"2025-03-31T15:49:27","slug":"tweya-tjekero-2","status":"publish","type":"dt_team","link":"https:\/\/www.parliament.na\/dt_team\/tweya-tjekero-2\/","title":{"rendered":"Tweya, Tjekero"},"content":{"rendered":"<table width=\"100%\" align=\"left\">\n<tbody>\n<tr>\n<td><img decoding=\"async\" class=\"alignnone size-full wp-image-7327\" src=\"https:\/\/www.parliament.na\/wp-content\/uploads\/2021\/04\/Hon_Tweya.jpg\" alt=\"\" width=\"136\" height=\"204\" \/><\/td>\n<td valign=\"top\">\n<p class=\"contact-position\"><strong>Member of Parliament &#8211; National Assembly <\/strong><\/p>\n<p class=\"contact-street\">Address: Private Bag 13323, Windhoek<\/p>\n<p class=\"contact-country\">SWAPO Party<\/p>\n<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\" width=\"25%\"><strong>Legislative Profile<\/strong><\/td>\n<td valign=\"top\">Chairperson: Standing Committee on Natural Resources (2020 &#8211; 2025); President of National Union of Namibian Workers (NUNW) 1991 \u2013 1993; Founding National Chairman of Namibia National Teachers Union (NANTU) 1989 &#8211; 1991; Member of SWAPO Party Central Committee since 2002; Deputy Minister of Finance 2005 -2010; Deputy Minister of Trade and Industry 2010 &#8211; 2015;\u00a0 Minister of Information and Communication Technology 2015 &#8211; 2018; Minister of Industrialization, Trade and SME Development since February 2018.<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Personal<\/strong><\/td>\n<td valign=\"top\">Born on 18 June 1960 at Shamundambo, Kavango Region<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Education<\/strong><\/td>\n<td valign=\"top\">Higher Education Diploma Hep (sec) 1988; Certificate in Senior Management from University of Manchester, UK 1992; BED (Honours) from University of Namibia (UNAM) 1993; Certificate in Budgeting in t