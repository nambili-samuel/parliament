{"id":4626,"date":"2021-05-08T15:02:54","date_gmt":"2021-05-08T13:02:54","guid":{"rendered":"http:\/\/154.0.202.153\/?post_type=dt_team&#038;p=4626"},"modified":"2021-08-17T09:15:02","modified_gmt":"2021-08-17T07:15:02","slug":"haingura-petrina-recalled","status":"publish","type":"dt_team","link":"https:\/\/www.parliament.na\/dt_team\/haingura-petrina-recalled\/","title":{"rendered":"Haingura Petrina (RECALLED)"},"content":{"rendered":"<table width=\"100%\" align=\"left\">\n<tbody>\n<tr>\n<td><img decoding=\"async\" class=\"alignnone size-full wp-image-7327\" src=\"https:\/\/www.parliament.na\/wp-content\/uploads\/2021\/05\/102_hon__petrina_haingura.jpg\" alt=\"\" width=\"136\" height=\"204\" \/><\/td>\n<td valign=\"top\">\n<p class=\"contact-position\"><strong>Member of Parliament: National Assembly<\/strong><\/p>\n<p class=\"contact-country\">Appointed By President<\/p>\n<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\" width=\"25%\"><strong>Legislative Profile<\/strong><\/td>\n<td valign=\"top\">Member of SWAPO Party (1980); Member of the South African Nursing Counsel\/Association (1980-1992); Member of the Namibian Nursing Counsel\/Association (1993); Member of NAPPA (1994); Member of SWAPO Women\u2019s Counsel in Kavango(1980) , Secretary from 1994 till 2002; Elected member of SWAPO Party Women\u2019s Central Committee (2001); Member of Ukumwe Cultural Group, Kavango Region (1998); Board member of LirongaEparu, Kavango Region (2001)<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Personal<\/strong><\/td>\n<td valign=\"top\">July 27, 1959 at Rupara, Kavango West Region<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Education<\/strong><\/td>\n<td valign=\"top\">Master Degree in Community Health, Department of Public Health,University of Liverpool, UK,2000; Diploma in Community Health, AMREF, Kenya, 1995 Advanced Diploma in Health Promotion and Diagnostics, University of Namibia, 1992; Diploma in Midwifery, Windhoek Nursing College, 1985; Diploma in Nursing, Oshakati Nursing College, 1984; Certificate in Nursing, Onandjokwe Lutheran Medical Hospital, 1980<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Career<\/strong><\/td>\n<td valign=\"top\">Deputy Minister of Health and Social Services (2005 up to date) \u2013 Appointed by the President); Secretary to the SWAPO Party Women\u2019s Council (2006 \u2013 2011 and re-elected 2011 -2016); Regional SWAPO Coordinator in Kavango Region (2002); Chief Health Programme Administrator (2001 \u2013 2002); Regional Primary Health Care Coordinator (1996 -2001); Registered Nurse\/Midwife in Rundu (1985-1996); Enrolled Nurse (1980-1981).<\/td>\n<\/tr>\n<tr>\n<td valign=\"top\"><strong>Interests<\/strong><\/td>\n<td valign=\"top\">Women empowerment; Fight HIV\/AIDS Pandemic; Fight alcohol and drug abuse; Fight Violence against Women and Children.<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n","protected":false},"excerpt":{"rendered":"<p>Member of Parliament: National Assembly Appointed By President Legislative Profile Member of SWAPO Party (1980); Member of the South African Nursing Counsel\/Association (1980-1992); Member of the Namibian Nursing Counsel\/Association (1993); Member of NAPPA (1994); Member of SWAPO Women\u2019s Counsel in Kavango(1980) , Secretary from 1994 till 2002; Elected member of SWAPO Party Women\u2019s Central Committee&hellip;<\/p>\n","protected":false},"featured_media":4627,"comment_status":"closed","ping_status":"closed","template":"","dt_team_category":[106,105,104],"class_list":["post-4626","dt_team","type-dt_team","status-publish","has-post-thumbnail","hentry","dt_team_category-4th-national-assembly-2005-2010","dt_team_category-5th-national-assembly-2010-2015","dt_team_category-6th-national-assembly-2015-2020","dt_team_category-106","dt_team_category-105","dt_team_category-104","description-off"],"_links":{"self":[{"href":"https:\/\/www.parliament.na\/wp-json\/wp\/v2\/dt_team\/4626","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.parliament.na\/wp-json\/